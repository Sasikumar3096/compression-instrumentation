{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "node",
		"declaration": true,
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"ts-node": {
		"transpileOnly": true,
		"compilerOptions": {
			"module": "commonjs",
			"moduleResolution": "node",
			"esModuleInterop": true
		}
	}
}
